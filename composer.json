{
  "name": "chubes4/static-site-importer",
  "type": "wordpress-plugin",
  "description": "Materialize compiled website artifacts into WordPress block themes.",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.1",
    "automattic/blocks-engine-php-transformer": "dev-trunk",
    "chubes4/block-artifact-compiler": "dev-main",
    "chubes4/block-format-bridge": "dev-main",
    "chubes4/html-to-blocks-converter": "dev-main"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../blocks-engine/php-transformer",
      "options": {
        "symlink": true
      }
    },
    {
      "name": "block-artifact-compiler",
      "type": "vcs",
      "url": "https://github.com/chubes4/block-artifact-compiler",
      "no-api": true
    },
    {
      "type": "vcs",
      "url": "https://github.com/chubes4/block-format-bridge",
      "no-api": true
    },
    {
      "type": "vcs",
      "url": "https://github.com/chubes4/html-to-blocks-converter",
      "no-api": true
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "sort-packages": true
  }
}

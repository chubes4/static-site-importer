{
  "auto_cleanup": false,
  "changelog_target": "docs/CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "html-to-blocks-converter",
  "remote_path": "wp-content/plugins/html-to-blocks-converter",
  "version_targets": [
    {
      "file": "html-to-blocks-converter.php",
      "pattern": "(?m)^\\s*\\*?\\s*Version:\\s*([0-9.]+)"
    },
    {
      "file": "library.php",
      "pattern": "(?m)^\\$html_to_blocks_library_version\\s*=\\s*'([0-9.]+)'"
    }
  ]
}
